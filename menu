}

handle_vscode_submenu() {
    local choice
    while true; do
        show_vscode_submenu
        read -r -p "Select: " -n 1 choice
        echo ""

        case "$choice" in
            1)
                open_log_in_editor "$LOG_DIR/datomic.log"
                return
                ;;
            2)
                open_log_in_editor "$LOG_DIR/server.log"
                return
                ;;
            3)
                open_log_in_editor "$LOG_DIR/figwheel.log"
                return
                ;;
            0|""|$'\e'|$'\x7f')
                return
                ;;
            *)
                echo -e "${YELLOW}Invalid choice${NC}"
