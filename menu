show_vscode_submenu() {
    echo ""
    echo -e "${BOLD}Open Log in VS Code${NC}"
    echo "───────────────────────────────────────"
    echo "  1) Datomic log"
    echo "  2) Server log"
    echo "  3) Figwheel log"
